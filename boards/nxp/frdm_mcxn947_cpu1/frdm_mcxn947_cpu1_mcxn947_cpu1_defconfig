# FRDM-MCXN947 CPU1 (SynapticOS application core)
# Cortex-M33 without FPU/DSP/TrustZone/MPU: no ARM_MPU, no
# HW_STACK_PROTECTION, no TRUSTED_EXECUTION_SECURE here.

# No console hardware for CPU1: single VCOM belongs to CPU0
CONFIG_CONSOLE=n
CONFIG_SERIAL=n
CONFIG_UART_CONSOLE=n

# Private SysTick at the 150 MHz core clock set up by CPU0
CONFIG_CORTEX_M_SYSTICK=y
CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=150000000
