# Out-of-tree board: FRDM-MCXN947 second core (CPU1).
# Zephyr 3.7's in-tree frdm_mcxn947 board only defines the cpu0
# target; this board provides the cpu1 target for SynapticOS
# asymmetric dual-core operation. CPU0 keeps the stock board.

config BOARD_FRDM_MCXN947_CPU1
	select SOC_MCXN947_CPU1 if BOARD_FRDM_MCXN947_CPU1_MCXN947_CPU1
	select SOC_PART_NUMBER_MCXN947VDF

# Zephyr 3.7's SOC_MCXN947_CPU1 symbol carries no CPU selects
# (upstream only fleshed out CPU0). Merge in the core type here.
# CPU1 is a Cortex-M33 WITHOUT FPU, DSP, TrustZone-M or MPU, so
# none of CPU0's CPU_HAS_* selects apply.
config SOC_MCXN947_CPU1
	select CPU_CORTEX_M33
