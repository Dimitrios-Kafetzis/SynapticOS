# SynapticOS Kconfig

menuconfig SYNAPTIC
    bool "SynapticOS AI Runtime"
    depends on SOC_SERIES_MCXNX4X || BOARD_QEMU_CORTEX_M3
    select CRC
    help
      Enable the SynapticOS AI-native runtime for inference
      scheduling, tensor memory management, and NPU orchestration.
      CRC support is selected for model integrity checks (CRC32 on
      registry commits and every model load).

if SYNAPTIC

config SYNAPTIC_TENSOR_ARENA_SIZE
    int "Tensor arena size in bytes"
    default 131072
    range 4096 524288
    help
      Size of the SRAM region dedicated to tensor allocations.
      Default 128 KB. Adjust based on model requirements.

config SYNAPTIC_SCRATCH_POOL_SIZE
    int "Scratch pool size in bytes"
    default 16384
    range 1024 65536
    help
      Size of the reusable scratch buffer pool for per-layer
      intermediate computations.

config SYNAPTIC_MAX_MODELS
    int "Maximum number of registered models"
    default 4
    range 1 16
    help
      Maximum number of models that can be registered in the
      model registry simultaneously.

config SYNAPTIC_MAX_CONCURRENT_JOBS
    int "Maximum concurrent inference jobs"
    default 2
    range 1 4
    help
      Maximum number of inference jobs that can be queued
      or running concurrently.

config SYNAPTIC_MAX_PIPELINE_STAGES
    int "Maximum stages per inference pipeline"
    default 8
    range 4 16
    help
      Maximum number of stages (preprocess + model + postprocess)
      in a single inference pipeline.

config SYNAPTIC_POWERQUAD
    bool "Use PowerQuad hardware acceleration"
    depends on SOC_SERIES_MCXNX4X
    default y
    help
      Route FFT and Q15 matrix operations through the PowerQuad
      coprocessor. Init runs known-answer self-calibration and
      falls back to the software kernels per-operation if it fails.

config SYNAPTIC_PROFILING
    bool "Enable inference profiling"
    default y if DEBUG
    help
      Enable per-inference profiling of execution time, memory
      usage, and NPU utilization. Zero overhead when disabled.

config SYNAPTIC_MODEL_STORE
    bool "Flash-backed model store"
    default y if !SOC_MCXN947_CPU1
    help
      Persist the model registry across reboots: two ping-pong
      registry copies (generation + CRC32, newest valid wins) plus
      A/B model slots, all accessed through a narrow flash port.
      On the FRDM-MCXN947 the store lives in the bank 1 tail above
      the CPU1 image reserve; on QEMU a RAM-backed port emulates
      the flash so the logic is fully unit-testable.

config SYNAPTIC_STORE_AUTO_INIT
    bool "Initialize the model store automatically at boot"
    depends on SYNAPTIC_MODEL_STORE
    default y
    help
      On boards with the MCX ROM-API flash HAL, bring the model
      store up over the generated partition map before main() so
      persistent models reappear without application code. Runs
      before CPU1 release; a failure only disables persistence.
      QEMU targets have no backing flash and initialize a RAM port
      explicitly instead.

config SYNAPTIC_OTA
    bool "Enable OTA model updates"
    depends on SYNAPTIC_MODEL_STORE
    default y
    help
      Enable over-the-air model update support using dual-bank
      flash with A/B slot management.

config SYNAPTIC_DUAL_CORE
    bool "Enable dual-core operation"
    depends on SECOND_CORE_MCUX
    default y
    help
      Enable asymmetric dual-core operation where CPU0 runs the
      AI runtime and CPU1 runs the application.

config SYNAPTIC_IPC_RING_SIZE
    int "IPC ring buffer entry count"
    default 16
    range 4 64
    depends on SYNAPTIC_DUAL_CORE
    help
      Number of entries in the inter-core IPC ring buffer.

config SYNAPTIC_SHARED_REGION_SIZE
    int "Shared memory region size in bytes"
    default 98304
    depends on SYNAPTIC_DUAL_CORE
    help
      Size of the shared SRAM region for IPC and tensor exchange
      between CPU0 and CPU1. Default 96 KB.

config SYNAPTIC_MPU_PROTECT
    bool "Cross-core MPU protection support"
    depends on SYNAPTIC_DUAL_CORE && ARM_MPU
    default y
    help
      Runtime support for cross-core memory protection: a fault
      policy that logs MPU violations and aborts only the offending
      thread (the other core is never affected), plus a self-test
      that provokes a guarded write. The guard is programmed at
      runtime into the last MPU region slot with an explicit
      read-only access encoding (a device-tree attribute would be
      silently rewritten to read-write by Kconfig options such as
      MPU_ALLOW_FLASH_WRITE, which SOC_FLASH_MCUX selects). Note:
      ARMv8-M cannot deny privileged reads while the background map
      is enabled, so only cross-core writes fault.

config SYNAPTIC_SHELL
    bool "Enable SynapticOS shell commands"
    depends on SHELL
    default y
    help
      Add shell commands for model management, profiling,
      and runtime inspection.

config SYNAPTIC_LOG_LEVEL
    int "SynapticOS log level"
    default 3
    range 0 4
    help
      0=OFF, 1=ERR, 2=WRN, 3=INF, 4=DBG

endif # SYNAPTIC
